<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>
	<connectionStrings>
		<add name="dbcon" connectionString="Server=localdb;Database=mydb;User Id=myUsername;Password=myPassword;"
			 providerName="System.Data.SqlClient" />
	</connectionStrings>
</configuration>